{
  "appId": "com.supercircuito.app",
  "appName": "Super CircuitoApp",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#000000",
    "appendUserAgent": "SuperCircuitoApp"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_notify",
      "iconColor": "#1E5FA8",
      "sound": "default"
    },
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#000000",
      "showSpinner": false,
      "splashImmersive": true
    }
  }
}
